  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#8B6068",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#FF8888"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "number"],
      "settings": {
        "foreground": "#FFA8B0"
      }
    },
    {
      "name": "Booleans",
      "scope": ["constant.language.true", "constant.language.false"],
      "settings": {
        "foreground": "#FFA8B0"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control"],
      "settings": {
        "foreground": "#FF5555"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "operator"],
      "settings": {
        "foreground": "#FF5555"
      }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function", "meta.function", "variable.function"],
      "settings": {
        "foreground": "#F5A8AB"
      }
    },
    {
      "name": "Methods",
      "scope": ["entity.name.function", "variable.function"],
      "settings": {
        "foreground": "#F5A8AB"
      }
    },
    {
      "name": "Types",
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "meta.type"],
      "settings": {
        "foreground": "#E67E80"
      }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.interface"],
      "settings": {
        "foreground": "#E67E80"
      }
    },
    {
      "name": "Structs",
      "scope": ["entity.name.struct"],
      "settings": {
        "foreground": "#E67E80"
      }
    },
    {
      "name": "Enums",
      "scope": ["entity.name.enum"],
      "settings": {
        "foreground": "#E67E80"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other", "variable.language"],
      "settings": {
        "foreground": "#F5A8AB"
      }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": {
        "foreground": "#F5A8AB"
      }
    },
    {
      "name": "Properties",
      "scope": ["variable.object.property", "property"],
      "settings": {
        "foreground": "#F5A8AB"
      }
    },
    {
      "name": "Constants",
      "scope": ["constant", "variable.other.constant", "entity.name.constant"],
      "settings": {
        "foreground": "#FFA8B0"
      }
    },
    {
      "name": "Tags",
      "scope": ["entity.name.tag", "meta.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#FF5555"
      }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name", "meta.attribute"],
      "settings": {
        "foreground": "#E67E80"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation", "meta.brace"],
      "settings": {
        "foreground": "#F5A8AB"
      }
    },
    {
      "name": "Null",
      "scope": ["constant.language.null"],
      "settings": {
        "foreground": "#8B6068"
      }
    },
    {
      "name": "Namespace",
      "scope": ["entity.name.namespace", "namespace"],
      "settings": {
        "foreground": "#E67E80"
      }
    },
    {
      "name": "Decorators",
      "scope": ["meta.decorator", "meta.decorator.identifier"],
      "settings": {
        "foreground": "#E67E80"
      }
    },
    {
      "name": "Import/Export",
      "scope": ["keyword.control.import", "keyword.control.export"],
      "settings": {
        "foreground": "#FF5555"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": ["markup.heading"],
      "settings": {
        "foreground": "#E67E80"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold", "strong"],
      "settings": {
        "foreground": "#FF5555",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic", "emphasis"],
      "settings": {
        "foreground": "#F5A8AB",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Links",
      "scope": ["markup.link", "text.link"],
      "settings": {
        "foreground": "#FFA8B0"
      }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "text.html.ruby"],
      "settings": {
        "foreground": "#FF8888"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#A87880"
      }
    },
    {
      "name": "Diff Added",
      "scope": ["markup.inserted", "diff.plus"],
      "settings": {
        "foreground": "#A7C080"
      }
    },
    {
      "name": "Diff Removed",
      "scope": ["markup.deleted", "diff.minus"],
      "settings": {
        "foreground": "#FF5555"
      }
    }
  ]
}
